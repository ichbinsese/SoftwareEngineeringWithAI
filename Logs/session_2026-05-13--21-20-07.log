    <Relationships>
      <Refines>HL-RUN-4.1</Refines>
      <DependsOn>LL-MAP-2.1.2</DependsOn>
    </Relationships>
    <Content>
      The system shall record the map cell corresponding to the robot’s starting position as the "start cell" before exploration begins.
    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.1.2">
    <Type>FR</Type>
    <Name>Path to Start Planning</Name>
    <Relationships>
      <Refines>HL-RUN-4.1</Refines>
      <DependsOn>LL-RUN-4.1.1</DependsOn>
      <DependsOn>LL-PLAN-3.1.1</DependsOn>
    </Relationships>
    <Content>
      The system shall, upon exploration completion, compute a path from the robot’s current cell to the recorded start cell using the path planning module.
    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.1.3">
    <Type>FR</Type>
    <Name>Return Path Execution</Name>
    <Relationships>
      <Refines>HL-RUN-4.1</Refines>
      <DependsOn>LL-RUN-4.1.2</DependsOn>
      <DependsOn>LL-INTERF-6.2.1</DependsOn>
    </Relationships>
    <Content>
      The system shall command the robot to follow the computed path back to the start cell and shall stop the robot when the start cell is reached within a defined positional tolerance.
    </Content>
  </Requirement>

  <!-- ===================================== -->
  <!-- HLR: HL-RUN-4.2 Second Run           -->
  <!-- ===================================== -->

  <Requirement ID="LL-RUN-4.2.1">
