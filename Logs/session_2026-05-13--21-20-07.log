  <Requirement ID="LL-RELIAB-5.1.1">
    <Type>FR</Type>
    <Name>Local Collision Avoidance Layer</Name>
    <Relationships>
      <Refines>HL-RELIAB-5.1</Refines>
      <DependsOn>LL-EXPL-1.3.2</DependsOn>
      <DependsOn>LL-INTERF-6.2.1</DependsOn>
    </Relationships>
    <Content>
