    </Content>
  </Requirement>

  <Requirement ID="LL-RELIAB-5.2.2">
    <Type>FR</Type>
    <Name>Fallback Behavior on Faulty Sensors</Name>
    <Relationships>
      <Refines>HL-RELIAB-5.2</Refines>
      <DependsOn>LL-RELIAB-5.2.1</DependsOn>
    </Relationships>
    <Content>
