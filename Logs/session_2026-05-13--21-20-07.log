    </Content>
  </Requirement>

  <Requirement ID="LL-RELIAB-5.2.3">
    <Type>NFR</Type>
    <Name>Fault Logging</Name>
    <Relationships>
      <Refines>HL-RELIAB-5.2</Refines>
      <DependsOn>LL-EXPL-1.1.5</DependsOn>
    </Relationships>
    <Content>
