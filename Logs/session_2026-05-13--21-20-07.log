    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.2.2">
    <Type>FR</Type>
    <Name>Second Run Path Selection</Name>
    <Relationships>
      <Refines>HL-RUN-4.2</Refines>
      <Refines>HL-RUN-4.3</Refines>
      <DependsOn>LL-PLAN-3.1.2</DependsOn>
    </Relationships>
    <Content>
      The system shall, before starting the second run, compute at least one path from the start cell to the target cell using the internal map and select the path with minimal travel cost for execution.
    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.2.3">
    <Type>FR</Type>
    <Name>Second Run Execution</Name>
    <Relationships>
      <Refines>HL-RUN-4.2</Refines>
      <Refines>HL-RUN-4.3</Refines>
      <DependsOn>LL-RUN-4.2.2</DependsOn>
