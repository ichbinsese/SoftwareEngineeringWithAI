    </Content>
  </Requirement>

  <Requirement ID="LL-RELIAB-5.1.2">
    <Type>NFR</Type>
    <Name>Safety Distance Enforcement</Name>
    <Relationships>
      <Refines>HL-RELIAB-5.1</Refines>
      <DependsOn>LL-RELIAB-5.1.1</DependsOn>
    </Relationships>
    <Content>
