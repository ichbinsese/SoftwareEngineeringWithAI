    <Name>Wall Detection from Sensor Data</Name>
    <Relationships>
      <Refines>HL-EXPL-1.2</Refines>
      <DependsOn>LL-EXPL-1.1.1</DependsOn>
    </Relationships>
    <Content>The robot shall detect walls using available sensors (e.g., LIDAR, sonar, or vision) and estimate the distance to walls; shall update the occupancy grid accordingly to reflect wall presence.</Content>
  </Requirement>

  <Requirement ID="LL-WALL-1.2.2">
    <Type>FR</Type>
    <Name>Wall Avoidance and Safe Navigation</Name>
    <Relationships>
      <Refines>HL-EXPL-1.2</Refines>
      <DependsOn>LL-WALL-1.2.1</DependsOn>
    </Relationships>
