<LLRequirements version="1" hierarchy="LLR">
  <Requirement ID="LL-EXPL-1.1">
    <Type>FR</Type>
    <Name>Exploration strategy initialization</Name>
    <Relationships>
      <Refines>HL-EXPL-1.1</Refines>
    </Relationships>
    <Content>Robot shall initialize exploration state, select an exploration strategy (wall-following or frontier-based), initialize internal map data structures, and begin collecting sensor data to support exploration.</Content>
  </Requirement>

  <Requirement ID="LL-EXPL-1.2">
    <Type>FR</Type>
    <Name>Wall detection integration during exploration</Name>
    <Relationships>
      <Refines>HL-EXPL-1.2</Refines>
      <DependsOn>LL-EXPL-1.1</DependsOn>
    </Relationships>
    <Content>Robot shall detect walls using available sensors (e.g., LIDAR, sonar) and integrate detections into the occupancy map to avoid collisions while exploring.</Content>
  </Requirement>

  <Requirement ID="LL-EXPL-1.3">
    <Type>FR</Type>
    <Name>Real-time collision avoidance during exploration</Name>
    <Relationships>
      <Refines>HL-EXPL-1.2</Refines>
      <DependsOn>LL-EXPL-1.2</DependsOn>
    </Relationships>
    <Content>Robot shall perform real-time collision avoidance by stopping, slowing, or re-planning when a potential collision is detected, ensuring a safe navigation margin.</Content>
  </Requirement>

  <Requirement ID="LL-EXPL-1.4">
    <Type>FR</Type>
    <Name>Wall detection reliability and integration</Name>
    <Relationships>
      <Refines>HL-EXPL-1.2</Refines>
      <DependsOn>LL-EXPL-1.2</DependsOn>
    </Relationships>
    <Content>Robot shall reliably detect walls under varying sensor noise conditions and integrate detections into the occupancy map to support safe exploration.</Content>
  </Requirement>

  <Requirement ID="LL-MAP-2.1">
    <Type>FR</Type>
    <Name>Internal map representation</Name>
    <Relationships>
      <Refines>HL-MAP-2.1</Refines>
      <DependsOn>LL-EXPL-1.2</DependsOn>
      <DependsOn>LL-EXPL-1.3</DependsOn>
    </Relationships>
    <Content>Robot shall implement an internal map data structure (e.g., occupancy grid or graph) with coordinates, resolution, and supports for incremental updates and map queries via a defined API.</Content>
  </Requirement>

  <Requirement ID="LL-MAP-2.2">
    <Type>FR</Type>
    <Name>Cell Classification</Name>
    <Relationships>
      <Refines>HL-MAP-2.2</Refines>
      <DependsOn>LL-MAP-2.1</DependsOn>
      <DependsOn>LL-EXPL-1.3</DependsOn>
    </Relationships>
    <Content>Robot shall classify cells as free, blocked, or unknown, fuse sensor data to update cell confidence, and maintain consistent occupancy information in the map.</Content>
  </Requirement>

  <Requirement ID="LL-MAP-2.3">
    <Type>NFR</Type>
    <Name>Mapping time constraint</Name>
    <Relationships>
      <Refines>HL-MAP-2.3</Refines>
      <DependsOn>LL-MAP-2.2</DependsOn>
    </Relationships>
    <Content>Mapping shall complete within 5 minutes for a standard maze; progress shall be observable via a status metric; if time is exceeded, the system shall degrade gracefully and continue mapping with best effort.</Content>
  </Requirement>

  <Requirement ID="LL-PLAN-3.1">
    <Type>FR</Type>
    <Name>Path planning engine</Name>
    <Content>Robot shall compute a path from the current position to the target using algorithms such as A* or D*, considering the current map state and safety constraints, and produce a sequence of waypoints.</Content>
    <Relationships>
      <Refines>HL-PLAN-3.1</Refines>
      <DependsOn>LL-MAP-2.2</DependsOn>
      <DependsOn>LL-MAP-2.3</DependsOn>
    </Relationships>
  </Requirement>

  <Requirement ID="LL-PLAN-3.2">
    <Type>FR</Type>
    <Name>Path representation and validation</Name>
    <Content>Robot shall define a data structure for paths (sequence of poses), validate planned paths against the current map, and ensure path traversability before execution.</Content>
    <Relationships>
      <Refines>HL-PLAN-3.1</Refines>
      <DependsOn>LL-PLAN-3.1</DependsOn>
    </Relationships>
  </Requirement>

  <Requirement ID="LL-PLAN-3.3">
    <Type>FR</Type>
    <Name>Dynamic replanning</Name>
    <Content>Robot shall monitor for map or sensor changes and trigger replanning within a bounded time, supporting asynchronous updates and partial path handling.</Content>
    <Relationships>
      <Refines>HL-PLAN-3.1</Refines>
      <DependsOn>LL-PLAN-3.2</DependsOn>
    </Relationships>
  </Requirement>

  <Requirement ID="LL-RUN-4.1">
    <Type>FR</Type>
    <Name>Return to start path execution</Name>
    <Content>Robot shall compute and execute a route back to the starting position after exploration, verify path safety, and handle interruptions or energy constraints gracefully.</Content>
    <Relationships>
      <Refines>HL-RUN-4.1</Refines>
      <DependsOn>LL-PLAN-3.3</DependsOn>
    </Relationships>
  </Requirement>

  <Requirement ID="LL-RUN-4.2">
    <Type>FR</Type>
    <Name>Second run execution</Name>
    <Content>Robot shall perform a second exploration pass to increase map coverage, applying a potentially different exploration strategy and avoiding previously visited areas where feasible.</Content>
    <Relationships>
      <Refines>HL-RUN-4.2</Refines>
      <DependsOn>LL-RUN-4.1</DependsOn>
    </Relationships>
  </Requirement>

