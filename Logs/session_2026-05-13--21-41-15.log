  </Requirement>

  <Requirement ID="LL-INTERF-6.2.3">
    <Type>FR</Type>
    <Name>Motor Command Limits</Name>
    <Relationships>
      <Refines>HL-INTERF-6.2</Refines>
      <Refines>HL-RELIAB-5.1</Refines>
