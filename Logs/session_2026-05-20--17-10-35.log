        </Component>

        <Component>
            <ID>CMP--17</ID>
            <Name>Environment Grid Coordinate System</Name>
            <Purpose>
                Defines coordinate system for mapping between physical maze positions and grid indices used across mapping, planning, and control modules.
                Responsibilities:
                - Provide 4x8 grid with consistent mapping from physical positions to (row, col) indices.
                - Define start cell coordinate convention (e.g. row=0, col=0).
                - Provide functions to convert between (x,y) positions and cell indices using cell size.
            </Purpose>
