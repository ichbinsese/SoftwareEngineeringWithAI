                        <Signal>
                            <Name>PoseEstimate</Name>
                            <Description>
                                Current discrete pose estimate: (row, col, headingIndex).
                                Used in EXPLORE, RETURN_TO_START, SECOND_RUN to determine start cell for path planning and to detect arrival at target cells or goal region cells.
                            </Description>
                        </Signal>
                        <Signal>
                            <Name>GoalRegionInfo</Name>
                            <Description>
                                Selected 2x2 goal region for second run:
