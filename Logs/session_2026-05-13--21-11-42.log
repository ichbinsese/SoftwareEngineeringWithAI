    </Content>
  </Requirement>

  <!-- Interfaces: sensor processing -->

  <Requirement ID="LL-INTERF-6.1.1">
    <Type>FR</Type>
    <Name>Sensor Data Acquisition Interface</Name>
    <Relationships>
      <Refines>HL-INTERF-6.1</Refines>
    </Relationships>
    <Content>
      The system shall implement an input interface that receives sensor data messages as specified in the sensor data interface description, including at least range, encoder, and optional inertial measurements.
    </Content>
  </Requirement>

  <Requirement ID="LL-INTERF-6.1.2">
    <Type>FR</Type>
    <Name>Sensor Data Timestamping</Name>
    <Relationships>
      <Refines>HL-INTERF-6.1</Refines>
      <Refines>HL-MAP-2.1</Refines>
    </Relationships>
    <Content>
      The system shall associate each received sensor data message with a timestamp from a monotonic clock and use these timestamps for pose estimation and time-based filtering.
    </Content>
  </Requirement>

  <Requirement ID="LL-INTERF-6.1.3">
    <Type>FR</Type>
    <Name>Sensor Data Fusion</Name>
