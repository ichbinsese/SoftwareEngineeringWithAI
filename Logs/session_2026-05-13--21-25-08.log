      <DependsOn>LL-INTERF-6.2.1</DependsOn>
      <DependsOn>LL-EXPL-1.3.3</DependsOn>
    </Relationships>
    <Content>
      The system shall command the actuators to follow the computed path back to the start pose while continuing to apply wall detection and collision avoidance.
    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.2.1">
    <Type>FR</Type>
