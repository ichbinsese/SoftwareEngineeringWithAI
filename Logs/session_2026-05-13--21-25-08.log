<Requirements version="1" hierarchy="LLR">
  <Requirement ID="LL-EXPL-1.1.1">
    <Type>NFR</Type>
    <Name>Requirement Typing Consistency</Name>
    <Relationships>
      <Refines>HL-EXPL-1.1</Refines>
    </Relationships>
    <Content>
      The system shall classify each requirement as either a Functional Requirement (FR) or a Non-Functional Requirement (NFR), and shall not use combined types such as "NFR / FR".
