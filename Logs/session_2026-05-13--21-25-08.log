    <Name>Exploration State Machine</Name>
    <Relationships>
      <Refines>HL-EXPL-1.2</Refines>
    </Relationships>
    <Content>
      The system shall implement an exploration state machine with, at minimum, the following states: IDLE, EXPLORE, RETURN_TO_START, SECOND_RUN, and ERROR, and shall transition between these states based on exploration progress and fault conditions.
    </Content>
  </Requirement>

  <Requirement ID="LL-EXPL-1.2.1">
