      <DependsOn>LL-PLAN-3.1.3</DependsOn>
      <DependsOn>LL-RUN-4.1.1</DependsOn>
    </Relationships>
    <Content>
      When exploration is marked as done, the system shall compute a path from the robot's current pose to the recorded start pose using the internal maze representation.
    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.1.3">
    <Type>FR</Type>
    <Name>Return Path Execution</Name>
    <Relationships>
