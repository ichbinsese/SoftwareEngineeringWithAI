      <DependsOn>LL-RUN-4.2.2</DependsOn>
    </Relationships>
    <Content>
      Before starting motion in the SECOND_RUN state, the system shall compute the shortest path from the start pose to the selected target cell using the final internal maze representation created during exploration.
    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.3.2">
    <Type>FR</Type>
    <Name>Second Run Path Execution</Name>
    <Relationships>
      <Refines>HL-RUN-4.3</Refines>
      <Refines>HL-INTERF-6.2</Refines>
      <Refines>HL-RELIAB-5.1</Refines>
