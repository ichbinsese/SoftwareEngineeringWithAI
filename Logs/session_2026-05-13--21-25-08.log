      <Refines>HL-MAP-2.2</Refines>
      <DependsOn>LL-MAP-2.1.4</DependsOn>
    </Relationships>
    <Content>
      When new map information changes the classification of any cell on the current planned path to BLOCKED, the system shall trigger replanning of the path to the current target from the robot's current position.
    </Content>
  </Requirement>

  <Requirement ID="LL-RUN-4.1.1">
    <Type>FR</Type>
    <Name>Start Pose Recording</Name>
    <Relationships>
